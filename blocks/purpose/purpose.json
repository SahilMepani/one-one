{
	"title": "Purpose",
	"fields": [
		{
			"key": "field_purpose_block_options",
			"label": "Purpose",
			"type": "accordion",
			"open": 1,
			"multi_expand": 1
		},
		{
			"key": "field_purpose_data_tab",
			"label": "Data",
			"type": "tab"
		},
		{
			"key": "field_purpose_label",
			"label": "Label",
			"name": "label",
			"type": "text"
		},
		{
			"key": "field_purpose_heading",
			"label": "Heading",
			"name": "heading",
			"type": "textarea",
			"rows": 2,
			"new_lines": "",
			"instructions": "Use line breaks to control wrapping."
		},
		{
			"key": "field_purpose_image",
			"label": "Image",
			"name": "image",
			"type": "image",
			"return_format": "id",
			"preview_size": "w200"
		},
		{
			"key": "field_purpose_columns",
			"label": "Columns",
			"name": "columns",
			"type": "repeater",
