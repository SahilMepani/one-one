			"max": 2,
			"layout": "block",
			"button_label": "Add Column",
			"sub_fields": [
				{
					"key": "field_purpose_columns_lead",
					"label": "Lead Text",
					"name": "lead",
					"type": "textarea",
					"rows": 2,
					"new_lines": "",
					"instructions": "Large opening line. Line breaks are preserved."
				},
				{
					"key": "field_purpose_columns_body",
					"label": "Body Text",
					"name": "body",
					"type": "wysiwyg",
					"toolbar": "basic",
					"media_upload": 0
				}
			]
		}
