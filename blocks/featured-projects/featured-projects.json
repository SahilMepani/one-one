{
	"title": "Featured Projects",
	"fields": [
		{
			"key": "field_featured_projects_block_options",
			"label": "Featured Projects",
			"type": "accordion",
			"open": 1,
			"multi_expand": 1
		},
		{
			"key": "field_featured_projects_data_tab",
			"label": "Data",
			"type": "tab"
		},
		{
			"key": "field_featured_projects_subheading",
			"label": "Subheading",
			"name": "subheading",
			"type": "text",
			"default_value": "Featured Project"
		},
		{
			"key": "field_featured_projects_heading",
			"label": "Heading",
			"name": "heading",
			"type": "textarea",
			"rows": 2,
			"new_lines": "br",
			"default_value": "The Story Behind a Piece"
		},
		{
			"key": "field_featured_projects_items",
			"label": "Projects",
			"name": "items",
			"type": "repeater",
			"min": 1,
			"layout": "block",
			"button_label": "Add Project",
			"collapsed": "field_featured_projects_items_description",
			"sub_fields": [
				{
					"key": "field_featured_projects_items_image",
					"label": "Image",
					"name": "image",
					"type": "image",
					"return_format": "id",
					"preview_size": "w200"
				},
				{
					"key": "field_featured_projects_items_description",
					"label": "Description",
					"name": "description",
					"type": "textarea",
					"rows": 3,
					"new_lines": "br"
				}
			]
		}
	]
}
