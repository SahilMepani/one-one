## ACF Link Button

```php
<?php
$link = get_field( 'link' );
if ( is_array( $link ) && $link['url'] ) : ?>
	<a
		href="<?php echo esc_url( $link['url'] ); ?>"
		target="<?php echo esc_attr( $link['target'] ); ?>"
		<?php echo ( '_blank' === $link['target'] ) ? 'rel="noopener noreferrer"' : ''; ?>
		class="btn btn-primary">
		<?php
		$text = ( $link['title'] ) ? $link['title'] : __( 'Learn More', 'skel' );
		echo '<span>' . esc_html( $text ) . '</span>';
		if ( '_blank' === $link['target'] ) {
			echo '<span class="sr-only">' . esc_html__( '(opens in a new tab)', 'skel' ) . '</span>';
		}
		?>
	</a>
<?php endif; ?>
```

## Repeater Loop

```php
<?php
$items = get_field( 'items' );
if ( is_array( $items ) && ! empty( $items ) ) :
	foreach ( $items as $item ) :
		$title = $item['title'] ?? '';
		$image = $item['image'] ?? '';
		$link  = $item['link'] ?? [];
		?>
		<div class="item">
			<?php if ( $title ) : ?>
				<h3><?php echo esc_html( $title ); ?></h3>
			<?php endif; ?>
		</div>
		<?php
	endforeach;
endif;
?>
```

## WP Query Loop

```php
<?php
$args = array(
	'post_type'      => 'post',
	'post_status'    => 'publish',
	'posts_per_page' => 6,
	'no_found_rows'  => true, // Disable pagination count for performance
	'update_post_term_cache' => false,
);

$query = new WP_Query( $args );

if ( $query->have_posts() ) :
	while ( $query->have_posts() ) :
		$query->the_post();
		?>
		<article <?php post_class(); ?>>
			<?php the_title( '<h2>', '</h2>' ); ?>
		</article>
		<?php
	endwhile;
	wp_reset_postdata();
endif;
?>
```

## Taxonomy Query

```php
<?php
$categories = get_field( 'categories' );  // ACF taxonomy field

$args = array(
	'post_type'      => 'post',
	'post_status'    => 'publish',
	'posts_per_page' => -1,
	'no_found_rows'  => true,
);

if ( is_array( $categories ) && ! empty( $categories ) ) {
	$args['tax_query'] = array(  // phpcs:ignore
		array(
			'taxonomy' => 'category',
			'terms'    => $categories,
			'field'    => 'id',
		),
	);
}

$query = new WP_Query( $args );
?>
```

